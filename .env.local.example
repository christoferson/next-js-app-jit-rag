# Copy to .env.local and fill in your values.

AWS_REGION=us-east-1
AWS_PROFILE=default                   # SSO: run `aws sso login` first
DATA_DIR=./data                       # root for file repos + LanceDB tables
DEFAULT_USER_ID=local-user            # AuthProvider stub

# Defaults (registry-overridable per notebook/document)
# Model IDs must exist in lib/models/registry.ts and be invocable in your account/region.
DEFAULT_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# NOTE: Anthropic models in this account require inference-profile IDs (us.…), verified 2026-07-24.
DEFAULT_LLM_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
DEFAULT_TOP_K=5
SCORE_THRESHOLD=0.0
MAX_FILE_MB=50
